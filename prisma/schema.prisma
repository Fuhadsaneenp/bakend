generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  OFFICE
  MEDICAL
}

enum ReimbursementStatus {
  NOT_READY
  READY
  PAID
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LetterType {
  OFFER
  EXPERIENCE
  RELIEVING
  CONFIRMATION
  CUSTOM
}

model Company {
  id          String       @id @default(cuid())
  name        String
  legalName   String?
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  departments Department[]
  employees   Employee[]
  payrollRuns PayrollRun[]
  clients     Client[]
  workCards   WorkCard[]
}

model User {
  id              String       @id @default(cuid())
  companyId       String?
  company         Company?     @relation(fields: [companyId], references: [id])
  email           String       @unique
  passwordHash    String
  role            Role
  refreshHash     String?
  isActive        Boolean      @default(true)
  employee        Employee?
  notifications   Notification[]
  auditLogs       AuditLog[]   @relation("ActorAuditLogs")
  statusHistories StatusHistory[]
  comments        Comment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Department {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  code        String
  employees   Employee[]
  designations Designation[]
  @@unique([companyId, code])
}

model Designation {
  id           String      @id @default(cuid())
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  title        String
  employees    Employee[]
}

model Employee {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id])
  managerId      String?
  manager        Employee?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports        Employee[]      @relation("ManagerReports")
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id])
  designationId  String?
  designation    Designation?    @relation(fields: [designationId], references: [id])
  employeeCode   String
  biometricId    String?         @unique
  firstName      String
  lastName       String
  phone          String?
  personalEmail  String?
  dateOfBirth    DateTime?
  gender         String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  emergencyContactName  String?
  emergencyContactPhone String?
  bankName       String?
  bankAccountNumber String?
  bankIfsc       String?
  taxId          String?
  dateOfJoining  DateTime
  status         EmployeeStatus  @default(ACTIVE)
  dateOfExit       DateTime?
  exitReason       String?
  exitRemarks      String?
  settlementStatus String?         @default("PENDING")
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  baseCurrency   String          @default("INR")
  salary         Salary?
  documents      EmployeeDocument[]
  letters        EmployeeLetter[]
  attendance     Attendance[]
  wfhRequests    WFHRequest[]
  expenseClaims  ExpenseClaim[]
  payslips       Payslip[]
  assignedWorkCards WorkCard[] @relation("AssignedWorkCards")
  createdWorkCards  WorkCard[] @relation("CreatedWorkCards")
  reworkCharged     ReworkLog[] @relation("ReworkCharged")
  pointsLedgers     PointsLedger[]
  ratingsGiven      Rating[] @relation("RatingsGiven")
  managedClients    Client[] @relation("ManagedClients")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  @@unique([companyId, employeeCode])
}

model Salary {
  id          String   @id @default(cuid())
  employeeId  String   @unique
  employee    Employee @relation(fields: [employeeId], references: [id])
  basic       Decimal  @db.Decimal(12, 2)
  allowances  Decimal  @db.Decimal(12, 2)
  deductions  Decimal  @db.Decimal(12, 2)
  effectiveFrom DateTime
  createdAt   DateTime @default(now())
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String
  status      String   @default("UPLOADED")
  fileKey     String
  fileName    String
  mimeType    String
  uploadedBy  String?
  verifiedAt  DateTime?
  verifiedBy  String?
  notes       String?
  uploadedAt  DateTime @default(now())
}

model EmployeeLetter {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id])
  type        LetterType
  title       String
  body        String     @db.Text
  fileKey     String?
  generatedBy String?
  issuedAt    DateTime   @default(now())
  createdAt   DateTime   @default(now())
}

model PayrollRun {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  month       Int
  year        Int
  processedBy String
  status      String    @default("PROCESSED")
  type        String    @default("REGULAR")
  grossTotal  Decimal   @db.Decimal(14, 2)
  netTotal    Decimal   @db.Decimal(14, 2)
  payslips    Payslip[]
  createdAt   DateTime  @default(now())
  @@unique([companyId, month, year, type])
}

model Payslip {
  id             String     @id @default(cuid())
  payrollRunId   String
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  payslipNumber  String     @unique
  month          Int
  year           Int
  basic          Decimal    @db.Decimal(12, 2)
  allowances     Decimal    @db.Decimal(12, 2)
  deductions     Decimal    @db.Decimal(12, 2)
  gratuity       Decimal    @default(0.00) @db.Decimal(12, 2)
  leaveEncashment Decimal   @default(0.00) @db.Decimal(12, 2)
  noticePay      Decimal    @default(0.00) @db.Decimal(12, 2)
  attendanceDays Int
  payableDays    Int
  grossPay       Decimal    @db.Decimal(12, 2)
  netPay         Decimal    @db.Decimal(12, 2)
  pdfKey         String?
  sentAt         DateTime?
  createdAt      DateTime   @default(now())
  @@unique([employeeId, month, year])
}

model Attendance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  workDate    DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  workMinutes Int       @default(0)
  overtimeMinutes Int   @default(0)
  isLate      Boolean   @default(false)
  latitude    Decimal?  @db.Decimal(10, 7)
  longitude   Decimal?  @db.Decimal(10, 7)
  @@unique([employeeId, workDate])
}

model WFHRequest {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      ApprovalStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime       @default(now())
}

model ExpenseClaim {
  id          String              @id @default(cuid())
  employeeId  String
  employee    Employee            @relation(fields: [employeeId], references: [id])
  category    ExpenseCategory
  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("INR")
  description String
  receiptKey  String?
  managerStatus ApprovalStatus    @default(PENDING)
  hrStatus    ApprovalStatus      @default(PENDING)
  reimbursementStatus ReimbursementStatus @default(NOT_READY)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Notification {
  id          String              @id @default(cuid())
  userId      String?
  user        User?               @relation(fields: [userId], references: [id])
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  subject     String
  body        String
  metadata    Json?
  createdAt   DateTime            @default(now())
  sentAt      DateTime?
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id])
  action      String
  entity      String
  entityId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Client {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  name             String
  details          String?      @db.Text
  contacts         String?      @db.Text
  accountManagerId String?
  accountManager   Employee?    @relation("ManagedClients", fields: [accountManagerId], references: [id])
  specialDays      SpecialDay[]
  workCards        WorkCard[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model SpecialDay {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  title     String
  type      String   // FESTIVAL, BIRTHDAY, ANNIVERSARY, CAMPAIGN
  date      DateTime
  createdAt DateTime @default(now())
}

model WorkCard {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  workId        String          @unique
  clientId      String
  client        Client          @relation(fields: [clientId], references: [id])
  title         String
  brief         String          @db.Text
  category      String
  priority      String          // URGENT, HIGH, NORMAL, LOW
  complexity    String          // SIMPLE, MEDIUM, HEAVY
  deadline      DateTime
  assignedToId  String?
  assignedTo    Employee?       @relation("AssignedWorkCards", fields: [assignedToId], references: [id])
  assignedById  String?
  assignedBy    Employee?       @relation("CreatedWorkCards", fields: [assignedById], references: [id])
  status        String          // PENDING, IN_PROGRESS, FINISHED, OUT_TO_DELIVER, APPROVED, REWORK
  reworkCount   Int             @default(0)
  files         String?         @db.Text // JSON string
  pointsEarned  Float?          @default(0)
  ratings       Rating[]
  statusHistory StatusHistory[]
  comments      Comment[]
  reworkLogs    ReworkLog[]
  pointsLedgers PointsLedger[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model StatusHistory {
  id         String   @id @default(cuid())
  workCardId String
  workCard   WorkCard @relation(fields: [workCardId], references: [id])
  status     String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model ReworkLog {
  id          String   @id @default(cuid())
  workCardId  String
  workCard    WorkCard @relation(fields: [workCardId], references: [id])
  roundNumber Int
  reason      String
  comment     String?  @db.Text
  chargedToId String?
  chargedTo   Employee? @relation("ReworkCharged", fields: [chargedToId], references: [id])
  createdAt   DateTime @default(now())
}

model PointsLedger {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  workCardId  String?
  workCard    WorkCard? @relation(fields: [workCardId], references: [id])
  points      Float
  description String
  createdAt   DateTime  @default(now())
}

model Rating {
  id         String   @id @default(cuid())
  workCardId String
  workCard   WorkCard @relation(fields: [workCardId], references: [id])
  rating     Int
  feedback   String?  @db.Text
  ratedById  String?
  ratedBy    Employee? @relation("RatingsGiven", fields: [ratedById], references: [id])
  createdAt  DateTime @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  workCardId String
  workCard   WorkCard @relation(fields: [workCardId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String   @db.Text
  createdAt  DateTime @default(now())
}

model WorkTrackSetting {
  id             String @id @default("settings")
  companyId      String @unique
  pointValues    String @db.Text // JSON string
  slaTimes       String @db.Text // JSON string
  categories     String @db.Text // JSON string
  reworkReasons  String @db.Text // JSON string
  promotionRules String @db.Text // JSON string
}
